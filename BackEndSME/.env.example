# ─────────────────────────────────────────────────────────────────────────────
# SME Back-End — Environment Variables Template
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# ⚠️  Never commit `.env` to Git. `.env` is in .gitignore.
# ⚠️  Generate strong secrets with:
#       node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
HOST_NAME=http://localhost
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Local Docker:    MONGO_URI=mongodb://db:27017
# Local dev (host): MONGO_URI=mongodb://127.0.0.1:27017
# Atlas (cloud):   MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?appName=SME
MONGO_URI=mongodb://db:27017
SME_DB_NAME=SME_db_mongo

# ── JWT — MUST be replaced with strong random secrets (>= 48 bytes base64) ───
JWT_SECRET=replace_me_with_crypto_random_48_bytes_base64
JWT_REFRESH_SECRET=replace_me_with_a_different_crypto_random_48_bytes_base64
ACCESS_EXPIRES=15m
REFRESH_EXPIRES=7d

# ── CORS — comma-separated list of allowed origins ───────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ── Rate limiting (optional — defaults are safe) ─────────────────────────────
# RATE_LIMIT_MAX=300
# RATE_LIMIT_AUTH_MAX=20

# ── MongoDB pool (optional) ──────────────────────────────────────────────────
# DB_POOL_MAX=10
# DB_POOL_MIN=2
# DB_IDLE_MS=30000

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info