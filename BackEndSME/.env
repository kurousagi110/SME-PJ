# ⚠️  FILE NÀY KHÔNG CÒN CHỨA CREDENTIALS THẬT.
# Tất cả secrets phải được inject từ Docker env (-e hoặc compose override),
# Kubernetes Secret, hoặc secret manager (Doppler / Vault / AWS Secrets Manager).
#
# File này được giữ làm template cho dev local. Copy từ .env.example và
# generate secrets mới bằng:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#
# ⚠️  Tất cả secrets đã được rotate ngày 2026-07-10.
# Không commit file này; secrets phải inject từ runtime env.

NODE_ENV=development
HOST_NAME=http://localhost
PORT=5000

# Local Docker (default). Đổi sang Atlas URL khi deploy ngoài.
MONGO_URI=mongodb://db:27017
SME_DB_NAME=SME_db_mongo

# JWT secrets — REPLACE with crypto-random 48-byte base64 strings.
# KHÔNG dùng placeholder này ngoài môi trường dev.
JWT_SECRET=replace_me_in_dev_with_crypto_random_48_bytes_base64
JWT_REFRESH_SECRET=replace_me_in_dev_with_a_different_crypto_random_48_bytes_base64
ACCESS_EXPIRES=15m
REFRESH_EXPIRES=7d

ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# RATE_LIMIT_MAX=300
# RATE_LIMIT_AUTH_MAX=20